AUTH_TYPE=OAuth2
DATABASE=(default)
DATABASE_REGION=asia-east1
DEFAULT_FROM=esther.shih@microfusion.cloud
DEFAULT_REPLY_TO=esther.shih@microfusion.cloud
firebaseextensions.v1beta.function/location=asia-east1
firebaseextensions.v1beta.function/minInstances=0
firebaseextensions.v1beta.function/vpcConnectorEgressSettings=VPC_CONNECTOR_EGRESS_SETTINGS_UNSPECIFIED
firebaseextensions.v1beta.v2function/memory=256Mi
HOST=smtp.gmail.com
MAIL_COLLECTION=mail
OAUTH_PORT=465
OAUTH_SECURE=true
SMTP_CONNECTION_URI=smtps://esther.shih@microfusion.cloud@smtp.gmail.com:465
SMTP_PASSWORD=projects/${param:PROJECT_NUMBER}/secrets/firestore-send-email-SMTP_PASSWORD/versions/latest
TTL_EXPIRE_TYPE=never
TTL_EXPIRE_VALUE=1